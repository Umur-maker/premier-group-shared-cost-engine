{
  "name": "premier-cost-engine",
  "version": "3.9.3",
  "description": "Premier Business Center - Shared Cost Engine",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.premier.costengine",
    "productName": "Premier Cost Engine",
    "directories": {
      "output": "../dist-electron"
    },
    "artifactName": "PremierCostEngine-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.business",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "writeUpdateInfo": true,
      "contents": [
        { "x": 130, "y": 200, "type": "file" },
        { "x": 410, "y": 200, "type": "link", "path": "/Applications" },
        { "x": 270, "y": 380, "type": "file", "path": "../mac-fix-permissions.command" }
      ],
      "window": {
        "width": 600,
        "height": 500
      }
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Umur-maker",
      "repo": "premier-group-shared-cost-engine"
    },
    "extraResources": [
      {
        "from": "../backend/dist/run_server",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend/out",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/data-seed",
        "to": "seed-data",
        "filter": [
          "companies.json",
          "settings.json"
        ]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "splash.html"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
